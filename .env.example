VITE_API_URL=http://localhost:8000

# Backend DB (Neon/PostgreSQL)
USE_SQLITE=False
DB_NAME=neondb
DB_USER=your_neon_user
DB_PASSWORD=your_neon_password
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_SSLMODE=require

# KBC source table mapping
KBC_TABLE_SCHEMA=public
KBC_TABLE_NAME=kbc_users_data
KBC_DOCTOR_COLUMN=FullName
KBC_GROUP_COLUMN=GroupName
KBC_MODULE_COLUMN=ModuleName
KBC_ATTENDANCE_TABLE_NAME=kbc_attendance
